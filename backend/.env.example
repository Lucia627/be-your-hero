# Be Your Hero - 环境变量配置
# 复制此文件为 .env 并填写真实值

# 服务器端口
PORT=8080

# 运行环境: development | production
NODE_ENV=production

# ========== LLM 配置 ==========
# 提供商: openai | claude | gemini | mock
LLM_PROVIDER=mock

# API 密钥（必需，除非使用 mock 模式）
LLM_API_KEY=your_api_key_here

# API 地址（OpenAI 默认，Claude/Gemini 需改）
LLM_API_URL=https://api.openai.com/v1/chat/completions

# 模型名称
LLM_MODEL=gpt-4o

# 强制使用模拟模式（无 API 密钥时使用）
LLM_MOCK_MODE=false

# ========== CORS 配置 ==========
# 允许的前端域名（逗号分隔）
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ========== 限流配置 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# ========== 数据备份 ==========
DATA_BACKUP_COUNT=5
DATA_BACKUP_INTERVAL_MS=3600000
